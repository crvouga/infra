{
  "name": "infra",
  "type": "module",
  "private": true,
  "scripts": {
    "gh": "open https://github.com/crvouga/infra/actions",
    "typecheck": "tsc --noEmit",
    "sync-dns": "bun run scripts/sync-dns.ts",
    "sync-redirects": "bun run scripts/sync-redirects.ts",
    "sync-aliases": "bun run scripts/sync-aliases.ts",
    "sync-railway-secrets": "bun run scripts/sync-railway-secrets.ts",
    "health-check": "bun run scripts/health-check-urls.ts",
    "provision-railway": "bun run scripts/provision-railway.ts",
    "rename-railway": "bun run scripts/rename-railway.ts",
    "deploy-railway": "bun run scripts/deploy-railway.ts",
    "make-ghcr-public": "bun run scripts/make-ghcr-public.ts",
    "seed-vault-github-secret": "bun run scripts/seed-vault-github-secret.ts",
    "destroy-fly": "bun run scripts/destroy-fly.ts",
    "destroy-railway": "bun run scripts/destroy-railway.ts",
    "cleanup-railway-deployments": "bun run scripts/cleanup-railway-deployments.ts",
    "destroy-digitalocean": "bun run scripts/destroy-digitalocean.ts",
    "rollout-publish": "bun run scripts/rollout-publish-workflows.ts",
    "print-platform-env": "bun run scripts/print-platform-env.ts",
    "vault:login": "vault login --method=userpass username=crvouga"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3",
    "yaml": "^2.8.1"
  }
}