#!/usr/bin/env bash
# secret-store-bao-wrapper
set -euo pipefail

if [ -z "${SECRET_STORE_CLI_ROOT:-}" ]; then
  WRAPPER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  SECRET_STORE_CLI_ROOT="$(cd "${WRAPPER_DIR}/.." && pwd)"
fi

# shellcheck source=../lib/openbao-auth.sh
source "${SECRET_STORE_CLI_ROOT}/lib/openbao-auth.sh"
# shellcheck source=../lib/config.sh
source "${SECRET_STORE_CLI_ROOT}/lib/config.sh"
# shellcheck source=../lib/run.sh
source "${SECRET_STORE_CLI_ROOT}/lib/run.sh"

subcommand="${1:-}"

case "$subcommand" in
  run)
    shift
    bao_run "$@" || exit $?
    ;;
  setup)
    shift
    bao_setup "$@" || exit $?
    ;;
  "")
    if ! resolve_bao_real_bin; then
      echo "ERROR: OpenBao CLI binary not found." >&2
      echo "       Install OpenBao: https://openbao.org/docs/install/" >&2
      echo "       Or run: ./scripts/install-cli.sh" >&2
      exit 1
    fi
    exec "$BAO_REAL_BIN"
    ;;
  -h|--help|help)
    cat <<EOF
secret-store bao wrapper — Doppler-style secret injection for self-hosted OpenBao.

Usage:
  bao run [OPTIONS] -- <command> [args...]   Run command with secrets injected
  bao setup [OPTIONS]                        Write .bao.yaml in current directory
  bao <command> ...                          Pass through to OpenBao CLI

Run 'bao run --help' or 'bao setup --help' for details.
EOF
    ;;
  *)
    if ! resolve_bao_real_bin; then
      echo "ERROR: OpenBao CLI binary not found." >&2
      echo "       Install OpenBao: https://openbao.org/docs/install/" >&2
      echo "       Or run: ./scripts/install-cli.sh" >&2
      exit 1
    fi
    exec "$BAO_REAL_BIN" "$@"
    ;;
esac
